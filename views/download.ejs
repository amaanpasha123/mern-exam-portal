<%- include("partials/header") %>

<h2 class="mb-4 text-center fw-bold">Available PDF Files</h2>


<div class="card shadow-lg border-0 rounded-4 mx-auto" style="max-width:700px;">
    <div class="card-body p-4">

        <% if (files.length === 0) { %>
            <div class="alert alert-warning text-center">
                No PDF files available for download.
            </div>
        <% } else { %>
            <ul class="list-group list-group-flush">
                <% files.forEach(function(file) { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>
                            📄 <%= file %>
                        </span>
                        <a href="/download/<%= file %>" 
                           class="btn btn-sm btn-primary">
                           Download
                        </a>
                    </li>
                <% }) %>

            </ul>

        <% } %>

        <div class="text-center mt-4">
            <a href="/upload" class="btn btn-success">
                Upload More PDFs
            </a>
        </div>

    </div>
</div>

<%- include("partials/fotter") %>